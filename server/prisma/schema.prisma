// 数据源配置 - MySQL
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Prisma 客户端生成器
generator client {
  provider = "prisma-client-js"
}

// ==========================================
// Agent: AI智能体配置
// ==========================================
model Agent {
  id                    BigInt  @id @default(autoincrement())
  name                  String  @db.VarChar(100)                 // Agent名称
  type                  String  @db.VarChar(32)  @default("assistant") // 类型: assistant
  system_prompt         String   @db.Text               // 系统提示词
  persona_prompt        String   @db.Text               // 角色设定提示词
  chat_model_id         BigInt?                          // 关联的ChatModel ID
  short_term_memory_config Json?                       // 短期记忆配置: { enabled: true, limitHistoryTurns: 10 }
  long_term_memory_config  Json?                        // 长期记忆配置: { enabled: true, autoExtract: true, extractIntervalTurns: 20 }
  enabled               Boolean  @default(true)        // 是否启用
  created_at            BigInt                            // 创建时间戳
  updated_at            BigInt                            // 更新时间戳

  chatModel             ChatModel?   @relation("AgentChatModel", fields: [chat_model_id], references: [id])
  threads               AgentThread[]
  memories              AgentMemory[]
  agentTools            AgentTool[]

  @@map("agent")
}

// ==========================================
// ChatModel: AI模型配置
// ==========================================
model ChatModel {
  id        BigInt  @id @default(autoincrement())
  name      String  @db.VarChar(100)                               // 模型配置名称
  provider  String  @db.VarChar(32)                               // 提供商: deepseek / openai / azure
  base_url  String? @db.VarChar(500)                              // API地址(可选，用于代理)
  api_key   String  @db.VarChar(500)                             // API密钥
  model     String  @db.VarChar(200)                             // 模型名称: deepseek-chat / gpt-4o
  enabled   Boolean @default(true)                               // 是否启用
  created_at BigInt                                                  // 创建时间戳
  updated_at BigInt                                                  // 更新时间戳

  agents    Agent[]  @relation("AgentChatModel")

  @@map("chat_model")
}

// ==========================================
// AgentThread: 对话线程
// 用户与Agent的一个会话上下文
// ==========================================
model AgentThread {
  id        BigInt  @id @default(autoincrement())
  agent_id  BigInt                           // 所属Agent ID
  user_id   String  @db.VarChar(100)          // 用户ID
  uuid      String @db.VarChar(36)           // 客户端提供的threadId(全局唯一)
  name      String? @db.VarChar(200)        // 线程名称
  created_at BigInt                            // 创建时间戳
  updated_at BigInt                            // 更新时间戳

  agent     Agent      @relation(fields: [agent_id], references: [id])
  chats     AgentChat[]

  @@unique([uuid, user_id])                   // 同一用户下threadId唯一
  @@index([agent_id, user_id])
  @@map("agent_thread")
}

// ==========================================
// AgentChat: 一次对话(一轮)
// 包含用户输入和对应的助手回复
// ==========================================
model AgentChat {
  id          BigInt  @id @default(autoincrement())
  agent_id    BigInt                           // 所属Agent ID
  thread_id   BigInt                           // 所属线程ID
  user_id     String  @db.VarChar(100)         // 用户ID
  content     String   @db.Text                // 用户本轮输入的消息
  metadata    Json?                           // 元数据(扩展字段)
  token_usage Json?                           // token使用量统计
  rating      Int?                            // 用户评分(可选)
  feedback    String?  @db.Text                // 用户反馈(可选)
  created_at  BigInt                             // 创建时间戳
  updated_at  BigInt                             // 更新时间戳

  thread      AgentThread    @relation(fields: [thread_id], references: [id])
  messages    AgentMessage[]

  @@index([thread_id, created_at])            // 按线程和时间查询
  @@index([agent_id, created_at])
  @@map("agent_chat")
}

// ==========================================
// AgentMessage: 对话消息
// 记录每轮对话中的每条消息(用户/助手/系统/工具)
// ==========================================
model AgentMessage {
  id          BigInt  @id @default(autoincrement())
  agent_id    BigInt                           // 所属Agent ID
  thread_id   BigInt                           // 所属线程ID
  chat_id     BigInt                           // 所属Chat ID
  user_id     String  @db.VarChar(100)         // 用户ID
  role        String  @db.VarChar(10)          // 角色: user / assistant / system / tool
  content     String   @db.Text                // 消息内容(JSON格式)
  token_usage Json?                           // token使用量统计
  created_at  BigInt                             // 创建时间戳

  chat        AgentChat @relation(fields: [chat_id], references: [id])

  @@index([thread_id, created_at])             // 按线程检索消息
  @@index([chat_id, created_at])               // 按Chat关联查询
  @@map("agent_message")
}

// ==========================================
// AgentMemory: 长期记忆
// 由AI自动总结的用户偏好、习惯等
// ==========================================
model AgentMemory {
  id        BigInt  @id @default(autoincrement())
  agent_id  BigInt                           // 所属Agent ID
  user_id   String  @db.VarChar(100)          // 用户ID
  content   String   @db.Text                // 记忆内容
  created_at BigInt                            // 创建时间戳
  updated_at BigInt                            // 更新时间戳

  agent     Agent    @relation(fields: [agent_id], references: [id])

  @@unique([agent_id, user_id])             // 每个用户每个Agent一条记忆
  @@index([agent_id])
  @@map("agent_memory")
}

// ==========================================
// Tool: 可用工具定义
// ==========================================
model Tool {
  id            BigInt  @id @default(autoincrement())
  name          String   @db.VarChar(100) @unique // 工具唯一名称
  description   String?                            // 工具描述
  type          String   @db.VarChar(20) @default("builtin") // 类型: builtin / mcp
  function_name String?  @db.VarChar(100)        // 函数名(用于builtin类型)
  mcp_server    String? @db.VarChar(1024)        // MCP服务器地址(用于mcp类型)
  prompt        String?  @db.Text                 // 工具使用提示词
  enabled       Boolean  @default(true)           // 是否启用
  created_at    BigInt                             // 创建时间戳
  updated_at    BigInt                             // 更新时间戳

  agentTools    AgentTool[]

  @@index([type])
  @@map("tool")
}

// ==========================================
// AgentTool: Agent与Tool的关联关系
// ==========================================
model AgentTool {
  agent_id BigInt
  tool_id  BigInt

  agent    Agent @relation(fields: [agent_id], references: [id])
  tool     Tool  @relation(fields: [tool_id], references: [id])

  @@id([agent_id, tool_id])
  @@map("agent_tool")
}
